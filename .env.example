# Optional: enable LLM-authored postmortem narratives.
# Homeostat's self-healing logic works WITHOUT any of these keys; they only
# affect the human-readable prose in incident postmortems.
#
# Copy this file to `.env` (which is git-ignored) and fill in a key.
# Provider is auto-selected: Gemini if GEMINI_API_KEY is set, else OpenAI.

GEMINI_API_KEY=your-gemini-api-key-here

# Optional overrides:
# HOMEOSTAT_LLM_PROVIDER=gemini        # force a provider: gemini | openai
# HOMEOSTAT_LLM_MODEL=gemini-1.5-flash # model name for the chosen provider
# OPENAI_API_KEY=your-openai-api-key-here
